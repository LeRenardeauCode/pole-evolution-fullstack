# IMPORTANT: Seeds strategy
# - main branch: users.js & cours.js are IGNORED (production security)
# - develop branch: users.js & cours.js are TRACKED with env variables
# This prevents exposing test credentials in production while keeping dev flexibility
# If you see users.js/cours.js in develop, it's expected and safe (uses env vars)
seeds/data/users.js
seeds/data/cours.js

