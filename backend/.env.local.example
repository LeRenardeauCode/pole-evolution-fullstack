# .env.local - LOCAL DEVELOPMENT ONLY
# This file is in .gitignore and should NEVER be committed
# Copy this as a template for your local development

NODE_ENV=development
PORT=5000

# MongoDB Local
MONGO_URI=mongodb://localhost:27017/poleevolution

# JWT
JWT_SECRET=your_super_secret_key_change_in_prod
JWT_EXPIRE=24h

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Seeds (development only) - use env variables instead of hardcoding
SEED_ADMIN_PASSWORD=AdminPole123!
SEED_USER_PASSWORD=UserPole1234!
