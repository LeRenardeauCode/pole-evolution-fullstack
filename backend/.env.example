# Backend environment (example)

NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/poleevolution

# JWT
JWT_SECRET=change_me
JWT_EXPIRE=24h

# Frontend URL (CORS + links in emails)
FRONTEND_URL=http://localhost:5173

# Monitoring optionnel (Sentry)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# CAPTCHA contact (Google reCAPTCHA v2)
RECAPTCHA_SECRET_KEY=

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (SMTP or service)
EMAIL_SERVICE=gmail
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
# Admin notification recipient (defaults to EMAIL_USER if not set)
ADMIN_EMAIL=
# Seeds (development only)
# Only needed if NODE_ENV=development and you want to populate test data
SEED_ADMIN_PASSWORD=ChangeMe123!